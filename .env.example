# === Poietic Generator V4or (OpenRouter) ===
# Copier en .env puis renseigner. Charge par start-v4or.sh.

# Cle serveur OpenRouter (obligatoire). Jamais exposee au navigateur.
OPENROUTER_API_KEY=

# Base URL du provider (defaut OpenRouter). Couture : pointer vers un endpoint
# local compatible OpenAI (Ollama) plus tard. V4or = cloud par defaut.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modele de la machine O (observation serveur).
O_MODEL=google/gemini-3.5-flash

# Plafonds de tokens de sortie (maitrise des couts).
W_MAX_TOKENS=2000
O_MAX_TOKENS=2000

# Effort de raisonnement par defaut : minimal|low|medium|high (cout++ si eleve).
REASONING_EFFORT=low

# Kill-switch budget par session en USD (0 = pas de limite).
MAX_SESSION_USD=5

# Evolution vers C : activer la machine N (defaut false en V4or).
ENABLE_N=false

# Attribution OpenRouter (en-tetes HTTP-Referer / X-Title).
APP_URL=http://localhost:3001
APP_TITLE="Poietic Generator V4or"

# Cadence d'analyse O (secondes).
O_CADENCE_SECONDS=25

# Identifiant de session du banc (doit correspondre au ?session= du front,
# defaut du front = "poietic-v4or"). Le cout de la machine O y est rattache.
SESSION_ID=poietic-v4or
